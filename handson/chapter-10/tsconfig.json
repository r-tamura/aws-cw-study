{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "outDir": ".",
    "rootDir": ".",
    "types": ["node", "jest"],
    "resolveJsonModule": true
  },
  "include": ["bin/**/*.ts", "lib/**/*.ts", "test/**/*.ts"],
  "exclude": [
    "node_modules",
    "cdk.out",
    "canaries",
    "**/*.d.ts",
    "**/*.js"
  ]
}
